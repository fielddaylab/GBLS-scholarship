# GBLS Literature Reviewer Environment Variables

# ============================================================================
# DEPLOYMENT ENVIRONMENTS
# ============================================================================

# For Local Development (localhost:8787)
NODE_ENV=development
PORT=8787
DEBUG_MODE=true
APP_URL=http://localhost:8787

# For Docker (localhost:8787)
# NODE_ENV=production
# PORT=8787
# DEBUG_MODE=true
# APP_URL=http://localhost:8787

# For Render.com Deployment
# NODE_ENV=production
# PORT=8080 (Render default)
# DEBUG_MODE=false (disable for production)
# RENDER=true (set by Render automatically)
# APP_URL will be auto-set from RENDER_EXTERNAL_URL

# ============================================================================
# DIRECTORIES
# ============================================================================
SUBMISSIONS_DIR=/tmp/submissions
CORPUS_DIR=../1_coded_gbls_corpus_articles
METRICS_DIR=../2_calculated_metrics

# For local development:
# SUBMISSIONS_DIR=./0_human_sources

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret (change to random value in production!)
JWT_SECRET=your-secret-key-change-in-production-to-random-string

# Debug Mode (DEVELOPMENT ONLY - disable in production!)
# When enabled: users can login with just an email (auto-creates user)
# When disabled: users must register or use OAuth
DEBUG_MODE=true

# GitHub OAuth (optional - not yet configured)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_CALLBACK_URL=http://localhost:8787/auth/github/callback

# Google OAuth (optional - not yet configured)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:8787/auth/google/callback

# reCAPTCHA (optional - for registration verification)
# RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
