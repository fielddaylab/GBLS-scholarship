# ============================================================
# .env.example — copy to .env and fill in real values
#
# ONLY secrets belong here. Paths, ports, URLs, and directory
# structure are all hardcoded in site/config.mjs with sensible
# defaults for every environment (local, Docker, Render).
#
# For Render production deployments, set these same keys as
# secret environment variables in the Render dashboard (not
# in render.yaml, which is committed to the repo).
# ============================================================

# --- Behaviour -------------------------------------------------
# Set to true locally to allow login with any email (no registration).
# Do NOT set on Render — the default is false.
DEBUG_MODE=true

# --- Auth secrets (required) -----------------------------------
#Generate this with 'openssl rand -hex 32'
JWT_SECRET=replace-with-a-long-random-string

# GitHub OAuth — create an app at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth — create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Zotero API — https://www.zotero.org/settings/keys
ZOTERO_USER_ID=your_zotero_user_id
ZOTERO_API_KEY=your_zotero_api_key

# --- Optional --------------------------------------------------
# reCAPTCHA (leave commented out to disable)
# RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
